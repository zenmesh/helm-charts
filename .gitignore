# Helm chart packages
# Note: Chart packages (*.tgz) in the root directory ARE committed for Helm repo/Artifact Hub
# Only ignore chart packages in subdirectories (dependencies, build artifacts)
*.tar.gz

# Chart dependencies (in charts/ subdirectories)
charts/*.tgz
charts/**/*.tgz

# Temporary files
*.tmp
*.bak
*~

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# H004: Prevent ~ and .kube directories from being committed
# These are typically user home directory artifacts
~/
~/**
**/~
**/~/*/
.kube/
.kube/**
**/.kube/
**/.kube/**

# Prevent kubeconfig and home directory artifacts
~/
.kube/
**/.kube/
**/~/.kube/config
