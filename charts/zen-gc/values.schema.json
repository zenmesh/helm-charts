{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1,
      "default": 2,
      "description": "Number of replicas"
    },
    "namespace": {
      "type": "string",
      "default": "",
      "description": "Target namespace (defaults to release namespace if empty)"
    },
    "leaderElection": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable leader election for HA"
        },
        "electionID": {
          "type": "string",
          "default": "gc-controller-leader-election",
          "description": "Leader election ID"
        },
        "namespace": {
          "type": "string",
          "default": "",
          "description": "Leader election namespace (defaults to POD_NAMESPACE)"
        }
      },
      "required": ["enabled"]
    }
  },
  "required": ["leaderElection"]
}